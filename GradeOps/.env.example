# Required — Gemini API key used for rubric generation + grading
GEMINI_API_KEY=

# Optional — SMTP settings to auto-email grade reports to students.
# If left unset, grading still works, emails are just skipped (logged to console).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional — used to build the re-evaluation link inside the emailed report
APP_URL=http://localhost:3000
